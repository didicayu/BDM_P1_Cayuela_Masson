# Copy to .env and set your values.
# .env is gitignored.

# NVD API key 
NVD_API_KEY=replace_with_your_nvd_key
ABUSE_CH_API_KEY=replace_with_your_abuse_ch_api_key
SHODAN_API_KEY=replace_with_your_shodan_api_key
PCAP_SOURCE_PROFILE=subset
SHODAN_ENABLED=false
EPSS_RESULTS_PER_PAGE=1000
EPSS_MAX_PAGES=10
CIRCL_TOP_N_CVES=200
THREATFOX_DAYS=1
SHODAN_MAX_INDICATORS_PER_RUN=50
SHODAN_REQUEST_SLEEP_SECONDS=1.0
SHODAN_SEED_IPS=

# Docker Compose defaults 
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
LANDING_BACKEND=minio
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_BUCKET=landing
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_KEY_PREFIX=
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_PORT=5433
AIRFLOW_UID=50000
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin
