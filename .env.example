# Copy to .env and set your values.
# .env is gitignored.

# NVD API key 
NVD_API_KEY=replace_with_your_nvd_key
ABUSE_CH_API_KEY=replace_with_your_abuse_ch_api_key
SHODAN_API_KEY=replace_with_your_shodan_api_key
PCAP_SOURCE_PROFILE=subset
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
PCAP_REPLAY_ENABLED=false
PCAP_REPLAY_MAX_ARTIFACTS=1
PCAP_REPLAY_EVENT_TYPES=alert,flow,dns,http,tls
PCAP_REPLAY_ALLOW_DECOMPRESS=false
PCAP_REPLAY_MAX_BYTES=
PCAP_REPLAY_SURICATA_BIN=suricata
PCAP_REPLAY_INGEST_DATE=
PCAP_REPLAY_KAFKA_ENABLED=true
PCAP_REPLAY_KAFKA_STRICT=true
PCAP_REPLAY_KAFKA_SURICATA_TOPIC=suricata.events
PCAP_REPLAY_KAFKA_IDS_ALERT_TOPIC=ids.alerts
SHODAN_ENABLED=false
EPSS_RESULTS_PER_PAGE=1000
EPSS_MAX_PAGES=10
CIRCL_TOP_N_CVES=200
THREATFOX_DAYS=1
SHODAN_MAX_INDICATORS_PER_RUN=50
SHODAN_REQUEST_SLEEP_SECONDS=1.0
SHODAN_SEED_IPS=

# Docker Compose defaults 
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
LANDING_BACKEND=minio
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_BUCKET=landing
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_KEY_PREFIX=

# Delta Lake silver layer (s3://deltalake/ in MinIO)
DELTA_BUCKET=deltalake
DELTA_LOCAL_ROOT=
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_PORT=5433
AIRFLOW_UID=50000
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin
